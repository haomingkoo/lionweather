# macOS
.DS_Store
.AppleDouble
.LSOverride

# Python / FastAPI
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.hypothesis/
.venv/
venv/
*.egg-info/
dist/
build/

# Local env files (NEVER commit these!)
.env
.env.*
!.env.example
!.env.local.example

# Database files (NEVER commit production data!)
backend/*.db
backend/*.db-shm
backend/*.db-wal
*.sqlite
*.sqlite3

# ML Models (too large for git)
backend/models/*.pkl
backend/models/*.h5
backend/models/*.joblib
!backend/models/.gitkeep

# Node / Vite
node_modules/
dist/
.vite/
*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
Desktop.ini

# Temporary files
*.tmp
*.temp
.cache/

# Documentation artifacts (Kiro-specific - not needed in git)
