# macOS
.DS_Store
.AppleDouble
.LSOverride

# Python / FastAPI
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.hypothesis/
.venv/
venv/
*.egg-info/
dist/
build/

# Local env files (NEVER commit these!)
.env
.env.*
!.env.example
!.env.local.example

# Database files (NEVER commit production data!)
backend/*.db
backend/*.db-shm
backend/*.db-wal
*.sqlite
*.sqlite3

# ML Models (binary — too large for git)
backend/models/*.pkl
backend/models/*.h5
backend/models/*.joblib
!backend/models/.gitkeep
# JSON analysis artifacts are small enough to commit
!backend/models/*.json

# Node / Vite
node_modules/
dist/
.vite/
*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
Desktop.ini

# Temporary files
*.tmp
*.temp
.cache/

# Historical NEA data (too large for git, stored locally)
backend/nea_historical_data/

# Documentation artifacts (Kiro-specific - not needed in git)
APP_STATUS.md
BACKEND_POLLING_FIX.md
CRITICAL_BACKEND_ISSUES.md
CRITICAL_DEPLOYMENT_ISSUE.md
CURRENT_STATUS.md
FIXES_SUMMARY.md
IMPLEMENTATION_SUMMARY.md
INTEGRATION_TEST_RESULTS.md
LOCAL_TESTING_GUIDE.md
LOCATION_GRANULARITY_ANALYSIS.md
ML_FORECASTING_STRATEGY.md
ML_OPTIMIZATION_RESEARCH.md
ML_TRAINING_PLAN.md
NEIGHBORHOOD_LEVEL_PREDICTIONS.md
RATE_LIMIT_FIX.md
RESTART_*.md
SETUP_INSTRUCTIONS.md
SETUP_VERIFICATION.md
ANIMATION_VERIFICATION.md
TASK_EXECUTION_SUMMARY.md
URGENT_BACKEND_FIX_NEEDED.md
backend/*_SUMMARY.md
backend/*_STATUS.md
backend/*_GUIDE.md
backend/*_IMPLEMENTATION.md
backend/*_FIX.md
backend/*_RESULTS.md

# Kiro specs and configuration
.kiro/

