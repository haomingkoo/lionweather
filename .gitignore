# macOS
.DS_Store
.AppleDouble
.LSOverride

# Python / FastAPI
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.hypothesis/
.venv/
venv/
*.egg-info/
dist/
build/

# Local env files (NEVER commit these!)
.env
.env.*
!.env.example
!.env.local.example

# Database files (NEVER commit production data!)
backend/*.db
backend/*.db-shm
backend/*.db-wal
*.sqlite
*.sqlite3

# ML Models — *.joblib committed directly (each ~12MB, well within GitHub 50MB limit)
# If models grow >50MB each, migrate to Hugging Face Hub
backend/models/*.pkl
backend/models/*.h5
backend/models/cache/
!backend/models/.gitkeep

# Node / Vite
node_modules/
dist/
.vite/
*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
Desktop.ini

# Temporary files
*.tmp
*.temp
.cache/

# Historical NEA data (too large for git, stored locally)
backend/nea_historical_data/

